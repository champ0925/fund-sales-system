DASHSCOPE_API_KEY=api-key
# MySQL
DB_HOST=localhost
DB_USER=root
DB_PASS=123456
DB_NAME=fund_sales

# RAG 配置（使用默认路径，不配置则自动检测）
# RAG_KNOWLEDGE_PATH=./src/rag/knowledge
# RAG_PERSIST_DIR=./data/vectorstore

# 模型配置
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v1

# RAG检索配置
RAG_RETRIEVER_K=4
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_VECTOR_STORE=chroma

# RAG流式输出配置
RAG_STREAM_CHUNK_SIZE=15
RAG_STREAM_DELAY=0.02

# RAG文本分隔符配置（用|分隔多个分隔符）
RAG_SEPARATORS=\n\n|\n|。|.|；|;|，|,| |
